{
    "version": 2,
    "builds": [
        {
            "src": "serverless.php",
            "use": "vercel-php@0.6.2",
            "config": {
                "excludeFiles": ["lms-frontend/**", "meeting-server/**", "tests/**", "postman/**", "node_modules/**"]
            }
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(css|js|images)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/serverless.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "CACHE_STORE": "array",
        "SESSION_DRIVER": "cookie",
        "QUEUE_CONNECTION": "sync",
        "LOG_CHANNEL": "errorlog"
    }
}
