{
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "concurrently -n \"Laravel,Vite\" -c \"blue,magenta\" \"php artisan serve\" \"vite\"",
        "start": "php artisan serve --host=0.0.0.0 --port=$PORT",
        "server": "php artisan serve --port=8000",
        "meeting": "cd meeting-server && npm start",
        "show-urls": "node show-urls.js",
        "tunnel": "ngrok start --all --config=ngrok.yml",
        "start-monolith": "concurrently -n \"Laravel,Vite,Meeting\" -c \"blue,magenta,cyan\" \"php artisan serve\" \"vite\" \"npm run meeting\""
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-react": "^4.2.1",
        "axios": "^1.7.4",
        "concurrently": "^9.2.1",
        "laravel-vite-plugin": "^1.2.0",
        "tailwindcss": "^4.0.0",
        "vite": "^6.0.11"
    },
    "dependencies": {
        "@liveblocks/client": "^3.13.4",
        "@liveblocks/react": "^3.13.4",
        "@liveblocks/react-ui": "^3.13.4",
        "@react-pdf/renderer": "^4.3.2",
        "@tanstack/react-query": "^5.90.19",
        "@tanstack/react-query-devtools": "^5.91.2",
        "emoji-picker-react": "^4.18.0",
        "html2canvas": "^1.4.1",
        "html2pdf.js": "^0.14.0",
        "i18next": "^25.8.11",
        "i18next-browser-languagedetector": "^8.2.1",
        "jspdf": "^4.0.0",
        "lucide-react": "^0.294.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-easy-crop": "^5.5.6",
        "react-i18next": "^16.5.4",
        "react-qr-code": "^2.0.18",
        "react-quill": "^2.0.0",
        "react-quill-new": "^3.8.3",
